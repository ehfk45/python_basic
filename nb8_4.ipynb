    "import csv\n",
    "\n",
    "# open()은 내장함수\n",
    "with open(\"students.csv\", \"r\", encoding=\"utf-8\") as f:\n",
    "    # reader() : csv모듈안에 있는 함수\n",
    "    reader = csv.reader(f)\n",
    "    print(type(reader))\n",
    "\n",
    "    for row in reader:\n",
    "        print(row)\n",
    "        print(type(row))\n",
    "        "
