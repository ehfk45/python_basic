   "source": [
    "#패킹 언패킹시 * 연산자\n",
    "#a,b= [1,2,3,4]\n",
    "*a,b = [1,2,3,4]    \n",
    "print(a) # [1,2,3]\n",
    "print(b) # 4\n",
    "\n",
    "c,*d = (1,2,3,4)\n",
    "print(c) # 1\n",
    "print(d) # [2, 3, 4]\n",
    "\n",
    "e,*f,g = (1,2,3,4)\n",
    "print(e) # 1\n",
    "print(f) # [2, 3]\n",
    "print(g) # 4\n",
    "\n",
    "h = [1,2,3]\n",
    "print(h) # 1 2 3\n",
    "print(*h)\n"
   ]
  }
